{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/adminlove520/CyberSecurity-Skills/main/index.schema.json",
  "title": "CyberSecurity-Skills Index Schema",
  "description": "验证 index.json 文件的结构和完整性，确保所有技能索引数据符合规范。",
  "type": "object",
  "required": ["meta", "modules"],

  "properties": {
    "$schema": {
      "type": "string",
      "description": "引用本 schema 文件的 URL"
    },

    "meta": {
      "type": "object",
      "description": "项目元数据",
      "required": ["title", "description", "version", "total_skills", "total_modules", "last_updated", "standards"],
      "properties": {
        "title": {
          "type": "string",
          "description": "项目标题"
        },
        "description": {
          "type": "string",
          "description": "项目描述"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "语义化版本号 (SemVer)"
        },
        "total_skills": {
          "type": "integer",
          "minimum": 1,
          "description": "技能总数"
        },
        "total_modules": {
          "type": "integer",
          "minimum": 1,
          "description": "模块总数"
        },
        "last_updated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "最后更新日期 (YYYY-MM-DD)"
        },
        "standards": {
          "type": "array",
          "description": "参考的安全标准列表",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },

    "modules": {
      "type": "array",
      "description": "技能模块列表",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name_cn", "name_en", "emoji", "path", "skill_count", "skills"],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1,
            "description": "模块 ID"
          },
          "name_cn": {
            "type": "string",
            "description": "模块中文名称"
          },
          "name_en": {
            "type": "string",
            "description": "模块英文名称"
          },
          "emoji": {
            "type": "string",
            "description": "模块 Emoji 图标"
          },
          "path": {
            "type": "string",
            "description": "模块目录路径（相对于项目根目录）"
          },
          "skill_count": {
            "type": "integer",
            "minimum": 1,
            "description": "该模块包含的技能数"
          },
          "skills": {
            "type": "array",
            "description": "技能列表",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["name", "file", "difficulty"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "技能名称"
                },
                "file": {
                  "type": "string",
                  "description": "技能文件名（相对路径）",
                  "pattern": "\\.md$"
                },
                "difficulty": {
                  "type": "string",
                  "pattern": "^[★☆]{1,5}$",
                  "description": "难度等级 (1-5星)"
                }
              }
            }
          }
        }
      }
    }
  }
}
